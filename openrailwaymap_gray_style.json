{
  "version": 8,
  "name": "OpenRailwayMap gray lines",
  "sources": {
    "orm": {
      "type": "raster",
      "tiles": [
        "https://a.tiles.openrailwaymap.org/standard/{z}/{x}/{y}.png",
        "https://b.tiles.openrailwaymap.org/standard/{z}/{x}/{y}.png",
        "https://c.tiles.openrailwaymap.org/standard/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© OpenRailwayMap contributors"
    }
  },
  "layers": [
    {
      "id": "orm-base",
      "type": "raster",
      "source": "orm",
      "paint": {
        /*
         * Reduce saturation to turn the colourful OpenRailwayMap tiles into
         * grayscale so they blend into the background.  The value -1
         * completely desaturates the image.  You can adjust this if
         * you prefer a hint of colour.
         */
        "raster-saturation": -1,
        /*
         * Increase the brightness range so the white casing and
         * background stay light while the dark track lines become a light
         * grey.  The minimum brightness pushes darker pixels up, while
         * the maximum limits how bright the brightest pixels are.
         * These values were tuned empirically.
         */
        "raster-brightness-min": 0.85,
        "raster-brightness-max": 1.0,
        /*
         * Lower the contrast a little so the ELR labels remain crisp
         * while the track lines fade into the background.  You can
         * adjust this between -1 and 1.
         */
        "raster-contrast": -0.2
      }
    }
  ]
}
